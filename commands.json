        "drop":        "drop",
        "say hello":   "wave",
        "move box 1": "box1_routine1",
        "move box 2": "box2_routine1",
        "move box 3": "box3_routine1",
        "reverse box 1": "box1_routine_reverse",
        "reverse box 2": "box2_routine_reverse",
        "reverse box 3": "box3_routine_reverse"
    },

    "gesture_triggers": {
        "Pointing_Up":    "acknowledge",
        "Victory":        "wave",
        "ILoveYou":       "home",
        "Closed_Fist":    null,
        "Open_Palm":      null,
