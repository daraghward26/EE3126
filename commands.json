    "home": {
        "steps": [
            {"type": "home"}
        ]
    },

    "limits": {
        "steps": [
            {"type": "home"},
            {"type": "move", "axis": "T1_E", "target": "min", "return_zero": true, "wait": 1.0},
            {"type": "move", "axis": "Z",    "target": "min", "return_zero": true, "wait": 1.0},
            {"type": "move", "axis": "Y",    "target": "min", "return_zero": true, "wait": 1.0},
            {"type": "move", "axis": "X",    "target": "min", "return_zero": true, "wait": 1.0},
            {"type": "move", "axis": "T0_E", "target": "min", "return_zero": true, "wait": 1.0},
            {"type": "servo", "value": 0,  "wait": 1.0},
            {"type": "servo", "value": 45, "wait": 1.0},
            {"type": "servo", "value": 0,  "wait": 1.0},
            {"type": "servo", "value": 90, "wait": 1.0}
        ]
    },

    "acknowledge": {
        "steps": [
            {"type": "raw", "cmd": "G91",          "wait": 0.0},
            {"type": "raw", "cmd": "G1 X2 F1000",  "wait": 0.5},
            {"type": "raw", "cmd": "G1 X-4 F1000", "wait": 0.5},
            {"type": "raw", "cmd": "G1 X2 F1000",  "wait": 0.5}
        ]
    },

    "drop": {
        "steps": [
            {"type": "servo", "value": 0, "wait": 0.5}
        ]
    },

    "wave": {
        "steps": [
            {"type": "absolute", "X": 0.0, "Y": -360.0, "Z": 8.8, "T0_E": 0.0, "T1_E": 0.0, "wait": 1.0},
            {"type": "raw", "cmd": "G91",            "wait": 0.0},
            {"type": "raw", "cmd": "G1 Y-100 F10000","wait": 0.7},
            {"type": "raw", "cmd": "G1 Y200 F10000", "wait": 0.7},
            {"type": "raw", "cmd": "G1 Y-100 F10000","wait": 0.7},
            {"type": "raw", "cmd": "G1 X2 F1000",   "wait": 0.5},
            {"type": "raw", "cmd": "G1 X-4 F1000",  "wait": 0.5},
            {"type": "raw", "cmd": "G1 X4 F1000",   "wait": 0.5},
            {"type": "raw", "cmd": "G1 X-2 F1000",  "wait": 0.5},
